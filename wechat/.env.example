# ========================================
# 微信个人号 Cursor Remote Control 环境变量配置
# ========================================
# 首次使用：cp .env.example .env
# 然后编辑 .env 填入你的实际凭据
# First-time setup: cp .env.example .env
# Then edit .env with your actual credentials
# ========================================

# Cursor Agent CLI
# 推荐使用 agent login 登录，无需配置此项
# Recommended: Use `agent login`, no need to configure this
# CURSOR_API_KEY=

# 模型 (推荐 auto 节省配额 / Recommend: auto to save quota)
# 可选 / Options: opus-4.6-thinking, sonnet-4, auto
# 默认模型（如果不设置，使用 shared/models-config.ts 中的 DEFAULT_MODEL）
# CURSOR_MODEL=opus-4.6

# 微信登录（首次启动自动扫码，无需配置）
# WeChat login (Auto QR code on first start, no config needed)
# Token 会自动保存到 .wechat_token.json
# Token will be saved to .wechat_token.json automatically

# 向量记忆（可选）
VOLC_EMBEDDING_API_KEY=your_embedding_api_key
VOLC_EMBEDDING_MODEL=doubao-embedding-vision-250615

# 记忆系统优化配置（OpenClaw 风格，可选）
# 时间衰减半衰期（天，默认30）
# MEMORY_TEMPORAL_DECAY_HALF_LIFE=30
# MMR 平衡参数（0=纯多样性, 1=纯相关性，默认0.5）
# MEMORY_MMR_LAMBDA=0.5
