# 环境变量和敏感信息
.env
.env.local
.env.*.local

# 依赖
node_modules/
**/node_modules/

# 日志
*.log
logs/
*.log.*
/tmp/*.log

# 构建产物
dist/
build/
*.js.map

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# macOS
.DS_Store

# 运行时文件
*.pid
*.sock

# 数据库
*.sqlite
*.sqlite-shm
*.sqlite-wal
.memory.sqlite*

# 收件箱
inbox/
**/inbox/

# 本地配置
plist/
*.plist

# 定时任务备份（scheduler 写入的 .bak，不应进仓库）
*.bak

# 项目路由配置（本机路径，每人不同）
projects.json

# Cursor 会话日志（本地对话记录）
.cursor/sessions/
**/.cursor/sessions/

# 定时任务存储（含 webhook 等敏感信息，运行时写入）
cron-jobs-dingtalk.json
cron-jobs-feishu.json
