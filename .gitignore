# 数据库
*.sqlite
*.sqlite-shm
*.sqlite-wal
.memory.sqlite*

# 收件箱
inbox/
**/inbox/

# Apple 备忘录同步输出（sync-apple-notes 生成，含个人内容，不提交）
apple-notes/

# 本地配置
plist/
*.plist

# 定时任务备份（scheduler 写入的 .bak，不应进仓库）
*.bak

# 项目路由配置（本机路径，每人不同）
projects.json

# Cursor 根目录工作区配置（运行时从 templates/ 自动生成，不提交）
# 包含 OpenSpec 的 commands/ 和 skills/，每台机器运行 openspec init 生成
/.cursor/

# Cursor 会话日志（本地对话记录）
.cursor/sessions/
**/.cursor/sessions/

# Bug修复报告（临时文档，不提交）
.cursor/*-REPORT.md
.cursor/BUG-FIX-*.md

# 定时任务存储（含 webhook 等敏感信息，运行时写入）
cron-jobs-dingtalk.json
cron-jobs-feishu.json
cron-jobs-wecom.json

# 临时研究文档（AI 生成的探索性文档）
feilian-*.md
*-research.md
*-test-report.md
TEST-*.md
*-REPORT.md

# 根目录 AGENTS.md（包含本机路径，使用 .cursor/AGENTS.md 代替）
/AGENTS.md

# .cursor/README.md（包含硬编码路径，用 AGENTS.md 和 CRON-TASK-RULES.md 代替）
/.cursor/README.md

# 模板和用户文档（包含本机路径或过时信息）
/feishu/templates/
/docs/
!docs/plans/
!docs/news-push-usage.md
!docs/news-push-deployment-checklist.md
!docs/news-platform-config.md

# 私人新闻源配置（每人不同，不提交）
config/news-sources.json

# 平台会话数据（运行时生成）
dingtalk/.sessions.json
feishu/.sessions.json
wecom/.sessions.json
