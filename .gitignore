# 环境变量和敏感信息
.env
.env.local
.env.*.local

# 依赖
node_modules/
**/node_modules/

# 日志
*.log
logs/
*.log.*
/tmp/*.log

# 缓存
.cache/

# Bun 等误生成的打包文件：与 shared/*.ts 同名时会优先被 import '.../foo.js' 加载，导致运行逻辑落后于源码
shared/command-handler.js

# 构建产物
dist/
build/
out/
*.js.map
*.tgz
*.tsbuildinfo

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# macOS
.DS_Store

# Windows
Thumbs.db

# 运行时文件
*.pid
*.sock
*.tmp

# 数据库
*.sqlite
*.sqlite-shm
*.sqlite-wal
.memory.sqlite*

# 收件箱
inbox/
**/inbox/

# Apple 备忘录同步输出（sync-apple-notes 生成，含个人内容，不提交）
apple-notes/

# 本地配置
plist/
*.plist

# 定时任务备份（scheduler 写入的 .bak，不应进仓库）
*.bak

# 项目路由配置（本机路径，每人不同）
projects.json

# Cursor 根目录工作区配置（运行时从 templates/ 自动生成，不提交）
# 包含 OpenSpec 的 commands/ 和 skills/，每台机器运行 openspec init 生成
/.cursor/

# Cursor 会话日志（本地对话记录）
.cursor/sessions/
**/.cursor/sessions/

# Bug修复报告（临时文档，不提交）
.cursor/*-REPORT.md
.cursor/BUG-FIX-*.md

# 定时任务存储（含 webhook 等敏感信息，运行时写入）
cron-jobs-dingtalk.json
cron-jobs-feishu.json
cron-jobs-wecom.json
cron-jobs-wechat.json

# 临时研究文档（AI 生成的探索性文档）
feilian-*.md
*-research.md
*-test-report.md
TEST-*.md
*-REPORT.md

# 根目录 AGENTS.md（包含本机路径，使用 .cursor/AGENTS.md 代替）
/AGENTS.md

# .cursor/README.md（包含硬编码路径，用 AGENTS.md 和 CRON-TASK-RULES.md 代替）
/.cursor/README.md

# 模板和用户文档（包含本机路径或过时信息）
/feishu/templates/
/feishu/发送文件到飞书.md
# docs/ 目录中部分文档包含本机路径，仅提交技术文档
/docs/*
!/docs/cc-connect-comparison.md
!/docs/similar-projects.md
!/docs/ARCHITECTURE.md
!/docs/DEVELOPMENT.md
!/docs/TROUBLESHOOTING.md
!/docs/MEMORY-SYSTEM.md
!/docs/test-plan-*.md

# 私人配置文件（每人不同，不提交）
config/news-sources.json
config/model-config.json

# 平台会话数据（运行时生成）
dingtalk/.sessions.json
feishu/.sessions.json
wecom/.sessions.json

# 临时报告文档（AI 生成的审查报告）
DOCS-VERIFICATION-*.md
FINAL-CHECK-REPORT-*.md
REFACTOR-SUMMARY.md

# 微信 token 和同步文件
wechat/.wechat_token.json
wechat/.wechat_sync_buf
