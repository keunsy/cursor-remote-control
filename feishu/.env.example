# ========================================
# 飞书 Cursor Remote Control 环境变量配置
# ========================================
# 首次使用：cp .env.example .env
# 然后编辑 .env 填入你的实际凭据
# First-time setup: cp .env.example .env
# Then edit .env with your actual credentials
# ========================================

# Cursor Agent CLI
# 推荐使用 agent login 登录，无需配置此项
# Recommended: Use `agent login`, no need to configure this
# CURSOR_API_KEY=

# 飞书 Bot（长连接模式，无需公网地址）
# Feishu/Lark Bot (WebSocket long connection, no public URL needed)
FEISHU_APP_ID=cli_your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret

# 模型 (推荐 auto 节省配额 / Recommend: auto to save quota)
# 可选 / Options: opus-4.6-thinking, sonnet-4, auto
CURSOR_MODEL=auto

# 火山引擎语音识别 / Volcengine Speech Recognition (optional)
# https://www.volcengine.com/docs/6561/1354869
VOLC_STT_APP_ID=
VOLC_STT_ACCESS_TOKEN=

# 火山引擎向量嵌入 / Volcengine Embedding for Memory Search (optional)
VOLC_EMBEDDING_API_KEY=
VOLC_EMBEDDING_MODEL=doubao-embedding-vision-250615

# 智能项目切换检测 / Smart Project Detection (default: true)
# 当消息提到其他项目时，提示是否切换
# When message mentions another project, prompt to switch
# 设置为 false 关闭此功能 / Set to false to disable
SMART_PROJECT_DETECTION=true
